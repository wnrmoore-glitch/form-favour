{%- render 'breadcrumbs' -%}

<section class="contact-page page-width section">
  <div class="contact-page__grid">

    <!-- Left: info -->
    <div class="contact-page__info">
      <p class="eyebrow">We'd love to hear from you</p>
      <h1 class="contact-page__heading">Get in touch</h1>
      <p class="contact-page__sub">We're a small team and we genuinely care about every order. Expect a reply within 24 hours on business days.</p>

      <ul class="contact-page__details list-unstyled">
        <li>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <a href="mailto:hello@formandfavour.co.uk">hello@formandfavour.co.uk</a>
        </li>
        <li>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span>Mon–Fri, 9am–5pm GMT</span>
        </li>
      </ul>

      <div class="contact-page__links">
        <a href="/pages/faq">Browse our FAQ →</a>
        <a href="/pages/shipping-returns">Shipping &amp; Returns →</a>
      </div>
    </div>

    <!-- Right: form -->
    <div class="contact-page__form-wrap">
      {%- form 'contact', id: 'contact-form' -%}
        {%- if form.posted_successfully? -%}
          <div class="contact-page__success">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="20 6 9 17 4 12"/></svg>
            <h2>Message sent!</h2>
            <p>Thanks for getting in touch. We'll get back to you within 24 hours.</p>
          </div>
        {%- else -%}
          {%- if form.errors -%}
            <div class="contact-page__error">
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}

          <div class="contact-page__row">
            <div class="field">
              <label class="field__label" for="contact-name">Name <span aria-hidden="true">*</span></label>
              <input type="text" id="contact-name" name="contact[name]"
                class="field__input" autocomplete="name"
                value="{{ form.name }}" required>
            </div>
            <div class="field">
              <label class="field__label" for="contact-email">Email <span aria-hidden="true">*</span></label>
              <input type="email" id="contact-email" name="contact[email]"
                class="field__input" autocomplete="email"
                value="{{ form.email }}" required>
            </div>
          </div>

          <div class="field">
            <label class="field__label" for="contact-subject">Subject</label>
            <select id="contact-subject" name="contact[subject]" class="field__input">
              <option value="">Please select…</option>
              <option value="Order query">Order query</option>
              <option value="Returns & refunds">Returns &amp; refunds</option>
              <option value="Product question">Product question</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <div class="field">
            <label class="field__label" for="contact-body">Message <span aria-hidden="true">*</span></label>
            <textarea id="contact-body" name="contact[body]"
              class="field__input" rows="6"
              placeholder="Tell us how we can help…"
              required>{{ form.body }}</textarea>
          </div>

          <button type="submit" class="button contact-page__submit">Send message</button>
        {%- endif -%}
      {%- endform -%}
    </div>

  </div>
</section>

<style>
  .contact-page__grid {
    display: grid; grid-template-columns: 1fr 1.4fr; gap: 5rem; align-items: start;
  }
  .contact-page__heading { font-size: clamp(2rem, 4vw, 3rem) !important; margin: 0.5rem 0 1rem; }
  .contact-page__sub { color: var(--ff-stone); line-height: 1.7; margin-bottom: 2rem; }
  .contact-page__details { margin: 0 0 1.5rem; padding: 0; display: flex; flex-direction: column; gap: 0.75rem; }
  .contact-page__details li { display: flex; align-items: center; gap: 0.75rem; font-size: 0.9rem; }
  .contact-page__details svg { color: var(--ff-sage); flex-shrink: 0; }
  .contact-page__details a { color: var(--ff-charcoal); text-decoration: none; }
  .contact-page__details a:hover { color: var(--ff-sage-dk); }
  .contact-page__links { display: flex; flex-direction: column; gap: 0.5rem; }
  .contact-page__links a { font-size: 0.82rem; color: var(--ff-sage-dk); text-decoration: none; }
  .contact-page__links a:hover { text-decoration: underline; }
  .contact-page__row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .field { margin-bottom: 1.25rem; }
  .field select.field__input { cursor: pointer; }
  .contact-page__submit { width: 100%; margin-top: 0.5rem; }
  .contact-page__success {
    text-align: center; padding: 3rem 2rem;
    border: 2px solid var(--ff-sage); border-radius: var(--ff-radius-lg);
  }
  .contact-page__success svg { color: var(--ff-sage); margin-bottom: 1rem; }
  .contact-page__success h2 { margin: 0 0 0.5rem; }
  .contact-page__error {
    background: #fef2f2; border: 1px solid #fca5a5;
    border-radius: var(--ff-radius); padding: 1rem; margin-bottom: 1rem;
    font-size: 0.85rem; color: #dc2626;
  }
  @media (max-width: 899px) {
    .contact-page__grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .contact-page__row { grid-template-columns: 1fr; }
  }
</style>

{% schema %}
{ "name": "Contact page", "settings": [] }
{% endschema %}
