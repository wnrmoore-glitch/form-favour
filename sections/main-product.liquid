{%- assign product = product -%}
{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- unless current_variant.available -%}
  {%- assign current_variant = product.variants | where: 'available', true | first | default: product.selected_or_first_available_variant -%}
{%- endunless -%}

{%- render 'breadcrumbs' -%}
<div class="product-page page-width section">
  <div class="product-page__grid">

    <!-- Media gallery -->
    <div class="product-gallery">
      <div class="product-gallery__main" id="product-featured-image" data-product-zoom title="Click to enlarge">
        {%- if product.featured_image -%}
          <img
            id="product-main-image"
            data-zoom-trigger
            data-index="0"
            src="{{ product.featured_image | image_url: width: 900 }}"
            srcset="{{ product.featured_image | image_url: width: 600 }} 600w,
                    {{ product.featured_image | image_url: width: 900 }} 900w,
                    {{ product.featured_image | image_url: width: 1200 }} 1200w"
            sizes="(max-width: 749px) 100vw, 50vw"
            alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
            width="{{ product.featured_image.width }}"
            height="{{ product.featured_image.height }}"
            loading="eager"
            fetchpriority="high"
          >
        {%- endif -%}
      </div>

      {%- if product.images.size > 1 -%}
        <div class="product-gallery__thumbs">
          {%- for image in product.images limit: 6 -%}
            <button
              class="product-gallery__thumb{% if forloop.first %} product-gallery__thumb--active{% endif %}"
              data-src="{{ image | image_url: width: 900 }}"
              aria-label="View image {{ forloop.index }}"
            >
              <img
                src="{{ image | image_url: width: 120 }}"
                alt="{{ image.alt | escape | default: product.title | escape }}"
                width="120" height="120" loading="lazy"
              >
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Product info -->
    <div class="product-info">
      {%- if product.vendor != blank -%}
        <p class="product__vendor">{{ product.vendor | escape }}</p>
      {%- endif -%}

      <h1 class="product__title">{{ product.title }}</h1>

      <div class="product__price">
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="price--on-sale">
            <span class="price-item--sale">{{ current_variant.price | money }}</span>
            <span class="price-item--regular">{{ current_variant.compare_at_price | money }}</span>
          </span>
        {%- else -%}
          <span class="price">{{ current_variant.price | money }}</span>
        {%- endif -%}
      </div>

      {%- form 'product', product, id: 'product-form', novalidate: 'novalidate' -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}" id="variant-id-input">

        <!-- Variants (available stock only) -->
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            {%- assign option_position = option.position -%}
            <div class="product-option">
              <label class="product-option__label">
                {{ option.name }}:
                <span class="product-option__selected js-selected-{{ option.position }}">{{ option.selected_value }}</span>
              </label>
              <div class="product-option__values">
                {%- assign first_available_set = false -%}
                {%- for value in option.values -%}
                  {%- comment -%} Check if any in-stock variant has this value {%- endcomment -%}
                  {%- assign value_has_stock = false -%}
                  {%- for variant in product.variants -%}
                    {%- if variant.available -%}
                      {%- assign opt_val = variant.options[option_position | minus: 1] -%}
                      {%- if opt_val == value -%}
                        {%- assign value_has_stock = true -%}
                      {%- endif -%}
                    {%- endif -%}
                  {%- endfor -%}
                  {%- if value_has_stock -%}
                    {%- assign is_selected = false -%}
                    {%- if option.selected_value == value -%}
                      {%- assign is_selected = true -%}
                    {%- elsif first_available_set == false -%}
                      {%- assign is_selected = true -%}
                      {%- assign first_available_set = true -%}
                    {%- endif -%}
                    <label class="product-option__value">
                      <input
                        type="radio"
                        name="{{ option.name }}"
                        value="{{ value | escape }}"
                        {% if is_selected %}checked{% endif %}
                        class="sr-only"
                      >
                      <span class="product-option__swatch">{{ value }}</span>
                    </label>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endunless -%}

        <!-- Quantity -->
        <div class="product-quantity">
          <label class="product-quantity__label" for="quantity">Quantity</label>
          <div class="quantity">
            <button type="button" class="quantity__button js-qty-minus" aria-label="Decrease quantity">−</button>
            <input
              type="number" id="quantity" name="quantity"
              value="1" min="1"
              class="quantity__input"
              aria-label="Quantity"
            >
            <button type="button" class="quantity__button js-qty-plus" aria-label="Increase quantity">+</button>
          </div>
        </div>

        <button
          type="submit"
          name="add"
          class="button product-form__submit"
          {%- unless current_variant.available -%}disabled{%- endunless -%}
        >
          {%- if current_variant.available -%}
            Add to cart
          {%- else -%}
            Sold out
          {%- endif -%}
        </button>

      {%- endform -%}

      <!-- Judge.me star rating -->
      <div class="product__reviews-badge jdgm-widget jdgm-preview-badge" data-id="{{ product.id }}">
        {{ product.metafields.judgeme.badge }}
      </div>

      <!-- Accordion tabs -->
      <div class="product__accordions">
        {%- if product.description != blank -%}
          <details class="accordion" open>
            <summary class="accordion__title">Description</summary>
            <div class="accordion__content product__description rte">{{ product.description }}</div>
          </details>
        {%- endif -%}

        {%- render 'size-guide', product: product -%}

        <details class="accordion">
          <summary class="accordion__title">Shipping & Returns</summary>
          <div class="accordion__content">
            <p>Free UK standard shipping on orders over £50. Delivered in 3–7 business days.</p>
            <p>Easy 30-day returns on unused items. <a href="/pages/shipping-returns">Full details →</a></p>
          </div>
        </details>
      </div>
    </div>

  </div>
</div>

{%- render 'sticky-atc', product: product -%}
{%- render 'related-products', product: product, limit: 4 -%}
{%- render 'recently-viewed', product: product -%}

<!-- Judge.me full review widget -->
<div class="product-reviews page-width section">
  <div class="section__header text-center">
    <p class="eyebrow">Customer reviews</p>
  </div>
  <div id="judgeme_product_review" class="jdgm-widget jdgm-review-widget" data-id="{{ product.id }}">
    {{ product.metafields.judgeme.reviews }}
  </div>
</div>

{%- comment -%} Full-size image data for the lightbox {%- endcomment -%}
<script type="application/json" data-product-images>
[
  {%- for image in product.images -%}
    {{ image | image_url: width: 1600 | json }}{%- unless forloop.last -%},{%- endunless -%}
  {%- endfor -%}
]
</script>

<!-- Image lightbox -->
<div class="media-lightbox" data-lightbox aria-hidden="true" role="dialog" aria-label="Product image">
  <button class="media-lightbox__close" data-lightbox-close aria-label="Close">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  {%- if product.images.size > 1 -%}
    <button class="media-lightbox__nav media-lightbox__nav--prev" data-lightbox-prev aria-label="Previous">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 18l-6-6 6-6"/></svg>
    </button>
    <button class="media-lightbox__nav media-lightbox__nav--next" data-lightbox-next aria-label="Next">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"/></svg>
    </button>
  {%- endif -%}
  <img data-lightbox-img src="" alt="{{ product.title | escape }}">
</div>

<style>
  .product-page__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  /* Gallery */
  .product-gallery__main img {
    width: 100%; border-radius: var(--ff-radius-lg); object-fit: cover;
  }
  .product-gallery__thumbs {
    display: flex; gap: 0.75rem; margin-top: 1rem; flex-wrap: wrap;
  }
  .product-gallery__thumb {
    width: 72px; height: 72px; border-radius: var(--ff-radius);
    border: 2px solid transparent; overflow: hidden; cursor: pointer;
    background: none; padding: 0; transition: border-color var(--ff-transition);
  }
  .product-gallery__thumb img { width: 100%; height: 100%; object-fit: cover; }
  .product-gallery__thumb--active,
  .product-gallery__thumb:hover { border-color: var(--ff-sage); }
  /* Info */
  .product__vendor { font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ff-sage); margin: 0 0 0.5rem; }
  .product__title { font-size: clamp(1.6rem, 3vw, 2.25rem) !important; margin: 0 0 0.75rem; }
  .product__price { font-size: 1.3rem; font-weight: 600; margin-bottom: 1.5rem; }
  .price-item--sale { color: var(--ff-sage-dk); }
  .price-item--regular { text-decoration: line-through; color: var(--ff-stone-lt); font-size: 1rem; font-weight: 400; margin-left: 0.5rem; }
  /* Options */
  .product-option { margin-bottom: 1.25rem; }
  .product-option__label { font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; display: block; margin-bottom: 0.5rem; }
  .product-option__values { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .product-option__swatch {
    display: block; padding: 0.4rem 0.9rem;
    border: var(--ff-border-dk); border-radius: var(--ff-radius);
    font-size: 0.85rem; cursor: pointer;
    transition: background-color var(--ff-transition), color var(--ff-transition);
  }
  .product-option__value input:checked + .product-option__swatch {
    background: var(--ff-charcoal); color: var(--ff-cream); border-color: var(--ff-charcoal);
  }
  .product-option__value input:focus + .product-option__swatch { outline: 2px solid var(--ff-sage); outline-offset: 2px; }
  /* Quantity */
  .product-quantity { margin: 1.25rem 0; }
  .product-quantity__label { font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; display: block; margin-bottom: 0.5rem; }
  .quantity { display: inline-flex; align-items: center; border: var(--ff-border-dk); border-radius: var(--ff-radius); overflow: hidden; }
  .quantity__button { background: none; border: none; width: 40px; height: 44px; font-size: 1.1rem; cursor: pointer; color: var(--ff-charcoal); transition: background var(--ff-transition); }
  .quantity__button:hover { background: var(--ff-cream-dk); }
  .quantity__input { width: 50px; height: 44px; text-align: center; border: none; border-left: var(--ff-border-dk); border-right: var(--ff-border-dk); font-size: 0.9rem; color: var(--ff-charcoal); background: none; }
  /* Add to cart */
  .product-form__submit { width: 100%; margin-top: 1rem; padding: 1rem 2rem !important; font-size: 0.82rem !important; }
  .product__description { border-top: var(--ff-border); padding-top: 1.5rem; margin-top: 1.75rem; line-height: 1.8; color: var(--ff-charcoal-80); }
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }
  @media (max-width: 749px) {
    .product-page__grid { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>

<script>
  (function () {
    // Thumbnail switcher
    var thumbs = document.querySelectorAll('.product-gallery__thumb');
    var mainImg = document.getElementById('product-main-image');
    var currentIndex = 0;
    thumbs.forEach(function (thumb, i) {
      thumb.addEventListener('click', function () {
        thumbs.forEach(function (t) { t.classList.remove('product-gallery__thumb--active'); });
        this.classList.add('product-gallery__thumb--active');
        if (mainImg) { mainImg.src = this.dataset.src; mainImg.dataset.index = i; }
        currentIndex = i;
      });
    });

    // ---- Lightbox (click main image to enlarge) ----
    var lightbox = document.querySelector('[data-lightbox]');
    var dataEl = document.querySelector('[data-product-images]');
    var images = [];
    try { images = dataEl ? JSON.parse(dataEl.textContent) : []; } catch (e) {}
    if (lightbox && images.length) {
      var lbImg = lightbox.querySelector('[data-lightbox-img]');
      function openLB(i) {
        currentIndex = (i + images.length) % images.length;
        lbImg.src = images[currentIndex];
        lightbox.setAttribute('aria-hidden', 'false');
        lightbox.setAttribute('data-open', '');
        document.body.style.overflow = 'hidden';
      }
      function closeLB() {
        lightbox.removeAttribute('data-open');
        lightbox.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }
      if (mainImg) mainImg.addEventListener('click', function () { openLB(parseInt(mainImg.dataset.index || 0, 10)); });
      lbImg.addEventListener('click', closeLB);
      lightbox.querySelectorAll('[data-lightbox-close]').forEach(function (b) { b.addEventListener('click', closeLB); });
      var nextBtn = lightbox.querySelector('[data-lightbox-next]');
      var prevBtn = lightbox.querySelector('[data-lightbox-prev]');
      if (nextBtn) nextBtn.addEventListener('click', function (e) { e.stopPropagation(); openLB(currentIndex + 1); });
      if (prevBtn) prevBtn.addEventListener('click', function (e) { e.stopPropagation(); openLB(currentIndex - 1); });
      lightbox.addEventListener('click', function (e) { if (e.target === lightbox) closeLB(); });
      document.addEventListener('keydown', function (e) {
        if (lightbox.getAttribute('aria-hidden') === 'true') return;
        if (e.key === 'Escape') closeLB();
        if (e.key === 'ArrowRight' && nextBtn) openLB(currentIndex + 1);
        if (e.key === 'ArrowLeft' && prevBtn) openLB(currentIndex - 1);
      });
    }
    // Quantity stepper
    var input = document.querySelector('.quantity__input');
    document.querySelector('.js-qty-minus')?.addEventListener('click', function () {
      if (input && input.value > 1) input.value = parseInt(input.value) - 1;
    });
    document.querySelector('.js-qty-plus')?.addEventListener('click', function () {
      if (input) input.value = parseInt(input.value) + 1;
    });
    // ---- Variant selector: update id, price, availability ----
    var productVariants = [];
    try {
      productVariants = {{ product.variants | json }};
    } catch(e) {}

    function getSelectedOptions() {
      var opts = [];
      document.querySelectorAll('.product-option').forEach(function (group) {
        var checked = group.querySelector('input[type="radio"]:checked');
        if (checked) opts.push(checked.value);
      });
      return opts;
    }

    function findVariant(selectedOpts) {
      return productVariants.find(function (v) {
        return v.options.every(function (opt, i) { return opt === selectedOpts[i]; });
      });
    }

    function updateVariant() {
      var opts = getSelectedOptions();
      var variant = findVariant(opts);
      if (!variant) return;

      // Update hidden id
      var idInput = document.getElementById('variant-id-input');
      if (idInput) idInput.value = variant.id;

      // Update price display
      var priceEl = document.querySelector('.product__price');
      if (priceEl) {
        var price = (variant.price / 100).toFixed(2);
        var cmp = variant.compare_at_price;
        if (cmp && cmp > variant.price) {
          var cmpFormatted = (cmp / 100).toFixed(2);
          priceEl.innerHTML = '<span class="price--on-sale">'
            + '<span class="price-item--sale">£' + price + '</span>'
            + '<span class="price-item--regular">£' + cmpFormatted + '</span>'
            + '</span>';
        } else {
          priceEl.innerHTML = '<span class="price">£' + price + '</span>';
        }
      }

      // Update ATC button availability
      var submitBtn = document.querySelector('.product-form__submit');
      var stickyBtn = document.getElementById('sticky-atc-btn');
      if (submitBtn) {
        submitBtn.disabled = !variant.available;
        submitBtn.textContent = variant.available ? 'Add to cart' : 'Sold out';
      }
      if (stickyBtn) {
        stickyBtn.disabled = !variant.available;
        stickyBtn.textContent = variant.available ? 'Add to cart' : 'Sold out';
      }

      // Update URL without reload
      if (window.history && window.history.replaceState) {
        var url = new URL(window.location.href);
        url.searchParams.set('variant', variant.id);
        window.history.replaceState({}, '', url.toString());
      }

      // Update selected label text
      document.querySelectorAll('.product-option').forEach(function (group) {
        var checked = group.querySelector('input[type="radio"]:checked');
        var label = group.querySelector('[class*="js-selected"]');
        if (checked && label) label.textContent = checked.value;
      });
    }

    document.querySelectorAll('.product-option__value input').forEach(function (radio) {
      radio.addEventListener('change', updateVariant);
    });
    updateVariant(); // run on load to sync state
  })();
</script>

{% schema %}
{
  "name": "Product information",
  "settings": []
}
{% endschema %}
