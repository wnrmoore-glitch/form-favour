{%- assign product = product -%}
{%- assign current_variant = product.selected_or_first_available_variant -%}

<div class="product-page page-width section">
  <div class="product-page__grid">

    <!-- Media gallery -->
    <div class="product-gallery">
      <div class="product-gallery__main" id="product-featured-image">
        {%- if product.featured_image -%}
          <img
            id="product-main-image"
            src="{{ product.featured_image | image_url: width: 900 }}"
            srcset="{{ product.featured_image | image_url: width: 600 }} 600w,
                    {{ product.featured_image | image_url: width: 900 }} 900w,
                    {{ product.featured_image | image_url: width: 1200 }} 1200w"
            sizes="(max-width: 749px) 100vw, 50vw"
            alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
            width="{{ product.featured_image.width }}"
            height="{{ product.featured_image.height }}"
            loading="eager"
            fetchpriority="high"
          >
        {%- endif -%}
      </div>

      {%- if product.images.size > 1 -%}
        <div class="product-gallery__thumbs">
          {%- for image in product.images limit: 6 -%}
            <button
              class="product-gallery__thumb{% if forloop.first %} product-gallery__thumb--active{% endif %}"
              data-src="{{ image | image_url: width: 900 }}"
              aria-label="View image {{ forloop.index }}"
            >
              <img
                src="{{ image | image_url: width: 120 }}"
                alt="{{ image.alt | escape | default: product.title | escape }}"
                width="120" height="120" loading="lazy"
              >
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Product info -->
    <div class="product-info">
      {%- if product.vendor != blank -%}
        <p class="product__vendor">{{ product.vendor | escape }}</p>
      {%- endif -%}

      <h1 class="product__title">{{ product.title }}</h1>

      <div class="product__price">
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="price--on-sale">
            <span class="price-item--sale">{{ current_variant.price | money }}</span>
            <span class="price-item--regular">{{ current_variant.compare_at_price | money }}</span>
          </span>
        {%- else -%}
          <span class="price">{{ current_variant.price | money }}</span>
        {%- endif -%}
      </div>

      {%- form 'product', product, id: 'product-form', novalidate: 'novalidate' -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}">

        <!-- Variants -->
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div class="product-option">
              <label class="product-option__label">
                {{ option.name }}:
                <span class="product-option__selected js-selected-{{ option.position }}">{{ option.selected_value }}</span>
              </label>
              <div class="product-option__values">
                {%- for value in option.values -%}
                  <label class="product-option__value">
                    <input
                      type="radio"
                      name="{{ option.name }}"
                      value="{{ value | escape }}"
                      {% if option.selected_value == value %}checked{% endif %}
                      class="sr-only"
                    >
                    <span class="product-option__swatch">{{ value }}</span>
                  </label>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endunless -%}

        <!-- Quantity -->
        <div class="product-quantity">
          <label class="product-quantity__label" for="quantity">Quantity</label>
          <div class="quantity">
            <button type="button" class="quantity__button js-qty-minus" aria-label="Decrease quantity">−</button>
            <input
              type="number" id="quantity" name="quantity"
              value="1" min="1"
              class="quantity__input"
              aria-label="Quantity"
            >
            <button type="button" class="quantity__button js-qty-plus" aria-label="Increase quantity">+</button>
          </div>
        </div>

        <button
          type="submit"
          name="add"
          class="button product-form__submit"
          {%- unless current_variant.available -%}disabled{%- endunless -%}
        >
          {%- if current_variant.available -%}
            Add to cart
          {%- else -%}
            Sold out
          {%- endif -%}
        </button>

      {%- endform -%}

      <!-- Description -->
      {%- if product.description != blank -%}
        <div class="product__description rte">
          {{ product.description }}
        </div>
      {%- endif -%}
    </div>

  </div>
</div>

<style>
  .product-page__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  /* Gallery */
  .product-gallery__main img {
    width: 100%; border-radius: var(--ff-radius-lg); object-fit: cover;
  }
  .product-gallery__thumbs {
    display: flex; gap: 0.75rem; margin-top: 1rem; flex-wrap: wrap;
  }
  .product-gallery__thumb {
    width: 72px; height: 72px; border-radius: var(--ff-radius);
    border: 2px solid transparent; overflow: hidden; cursor: pointer;
    background: none; padding: 0; transition: border-color var(--ff-transition);
  }
  .product-gallery__thumb img { width: 100%; height: 100%; object-fit: cover; }
  .product-gallery__thumb--active,
  .product-gallery__thumb:hover { border-color: var(--ff-sage); }
  /* Info */
  .product__vendor { font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ff-sage); margin: 0 0 0.5rem; }
  .product__title { font-size: clamp(1.6rem, 3vw, 2.25rem) !important; margin: 0 0 0.75rem; }
  .product__price { font-size: 1.3rem; font-weight: 600; margin-bottom: 1.5rem; }
  .price-item--sale { color: var(--ff-sage-dk); }
  .price-item--regular { text-decoration: line-through; color: var(--ff-stone-lt); font-size: 1rem; font-weight: 400; margin-left: 0.5rem; }
  /* Options */
  .product-option { margin-bottom: 1.25rem; }
  .product-option__label { font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; display: block; margin-bottom: 0.5rem; }
  .product-option__values { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .product-option__swatch {
    display: block; padding: 0.4rem 0.9rem;
    border: var(--ff-border-dk); border-radius: var(--ff-radius);
    font-size: 0.85rem; cursor: pointer;
    transition: background-color var(--ff-transition), color var(--ff-transition);
  }
  .product-option__value input:checked + .product-option__swatch {
    background: var(--ff-charcoal); color: var(--ff-cream); border-color: var(--ff-charcoal);
  }
  .product-option__value input:focus + .product-option__swatch { outline: 2px solid var(--ff-sage); outline-offset: 2px; }
  /* Quantity */
  .product-quantity { margin: 1.25rem 0; }
  .product-quantity__label { font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; display: block; margin-bottom: 0.5rem; }
  .quantity { display: inline-flex; align-items: center; border: var(--ff-border-dk); border-radius: var(--ff-radius); overflow: hidden; }
  .quantity__button { background: none; border: none; width: 40px; height: 44px; font-size: 1.1rem; cursor: pointer; color: var(--ff-charcoal); transition: background var(--ff-transition); }
  .quantity__button:hover { background: var(--ff-cream-dk); }
  .quantity__input { width: 50px; height: 44px; text-align: center; border: none; border-left: var(--ff-border-dk); border-right: var(--ff-border-dk); font-size: 0.9rem; color: var(--ff-charcoal); background: none; }
  /* Add to cart */
  .product-form__submit { width: 100%; margin-top: 1rem; padding: 1rem 2rem !important; font-size: 0.82rem !important; }
  .product__description { border-top: var(--ff-border); padding-top: 1.5rem; margin-top: 1.75rem; line-height: 1.8; color: var(--ff-charcoal-80); }
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }
  @media (max-width: 749px) {
    .product-page__grid { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>

<script>
  (function () {
    // Thumbnail switcher
    var thumbs = document.querySelectorAll('.product-gallery__thumb');
    var mainImg = document.getElementById('product-main-image');
    thumbs.forEach(function (thumb) {
      thumb.addEventListener('click', function () {
        thumbs.forEach(function (t) { t.classList.remove('product-gallery__thumb--active'); });
        this.classList.add('product-gallery__thumb--active');
        if (mainImg) mainImg.src = this.dataset.src;
      });
    });
    // Quantity stepper
    var input = document.querySelector('.quantity__input');
    document.querySelector('.js-qty-minus')?.addEventListener('click', function () {
      if (input && input.value > 1) input.value = parseInt(input.value) - 1;
    });
    document.querySelector('.js-qty-plus')?.addEventListener('click', function () {
      if (input) input.value = parseInt(input.value) + 1;
    });
    // Variant label update
    document.querySelectorAll('.product-option__value input').forEach(function (radio) {
      radio.addEventListener('change', function () {
        var pos = this.closest('.product-option').querySelector('.product-option__label')
          ?.querySelector('[class*="js-selected"]');
        if (pos) pos.textContent = this.value;
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Product information",
  "settings": []
}
{% endschema %}
