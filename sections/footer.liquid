<footer class="footer" role="contentinfo">
  <div class="page-width">
    <div class="footer__grid">

      <!-- Brand column -->
      <div class="footer__brand">
        {%- if section.settings.logo -%}
          <img
            src="{{ section.settings.logo | image_url: width: 200 }}"
            alt="{{ shop.name }}"
            width="160"
            loading="lazy"
            class="footer__logo"
          >
        {%- else -%}
          <img
            src="https://cdn.shopify.com/s/files/1/0733/9887/8359/files/form-and-favour-logo-transparent.png?v=1780190020"
            alt="{{ shop.name }}"
            width="160"
            loading="lazy"
            class="footer__logo"
          >
        {%- endif -%}
        {%- if section.settings.tagline != blank -%}
          <p class="footer__tagline">{{ section.settings.tagline | escape }}</p>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="footer__description">{{ section.settings.description | escape }}</p>
        {%- endif -%}
        <!-- Social links -->
        <div class="footer__social">
          {%- if section.settings.instagram != blank -%}
            <a href="{{ section.settings.instagram }}" class="footer__social-link" aria-label="Instagram" target="_blank" rel="noopener">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.tiktok != blank -%}
            <a href="{{ section.settings.tiktok }}" class="footer__social-link" aria-label="TikTok" target="_blank" rel="noopener">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05A6.34 6.34 0 0 0 3.15 15.3a6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.34-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.02-.07z"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.facebook != blank -%}
            <a href="{{ section.settings.facebook }}" class="footer__social-link" aria-label="Facebook" target="_blank" rel="noopener">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Nav columns -->
      {%- for i in (1..3) -%}
        {%- assign menu_key = 'menu_' | append: i -%}
        {%- assign heading_key = 'heading_' | append: i -%}
        {%- assign menu = section.settings[menu_key] -%}
        {%- if menu != blank -%}
          <div class="footer__column">
            {%- if section.settings[heading_key] != blank -%}
              <h3 class="footer__heading">{{ section.settings[heading_key] | escape }}</h3>
            {%- endif -%}
            <ul class="footer__list list-unstyled" role="list">
              {%- for link in linklists[menu].links -%}
                <li class="footer__list-item">
                  <a href="{{ link.url }}" class="footer__link">{{ link.title | escape }}</a>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}

      <!-- Newsletter -->
      <div class="footer__column footer__newsletter">
        <h3 class="footer__heading">Stay in the edit</h3>
        <p style="font-size:0.82rem; margin-bottom:1rem; color:rgba(245,241,233,0.6)">New arrivals, behind the scenes, and exclusive offers.</p>
        {%- form 'customer', id: 'footer-newsletter' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="footer__newsletter-form">
            <input
              type="email" name="contact[email]"
              placeholder="Your email"
              required
              class="field__input footer__newsletter-input"
              aria-label="Email address"
            >
            <button type="submit" class="button footer__newsletter-btn">Subscribe</button>
          </div>
        {%- endform -%}
      </div>

    </div>

    <!-- Policy links row -->
    <div class="footer__policy-row">
      <a href="/pages/about">About Us</a>
      <a href="/pages/contact">Contact</a>
      <a href="/pages/faq">FAQ</a>
      <a href="/pages/shipping-returns">Shipping &amp; Returns</a>
      <a href="/pages/privacy-policy">Privacy Policy</a>
      <a href="/pages/terms-of-service">Terms of Service</a>
    </div>

    <!-- Bottom bar -->
    <div class="footer__bottom">
      <p>© {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      <p class="footer__payments">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'footer__payment-icon' }}
        {%- endfor -%}
      </p>
    </div>
  </div>
</footer>

<style>
  .footer { padding-top: 4rem; padding-bottom: 2rem; }
  .footer__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr 1.4fr;
    gap: 3rem;
  }
  .footer__logo { opacity: 0.85; margin-bottom: 1rem; filter: brightness(0) invert(1); }
  .footer__brand-name { font-family: var(--ff-font-heading); font-size: 1.4rem; color: var(--ff-cream); letter-spacing: 0.1em; }
  .footer__tagline { font-size: 0.68rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ff-sage-lt); margin: 0.25rem 0 0.75rem; }
  .footer__description { font-size: 0.83rem; line-height: 1.7; }
  .footer__social { display: flex; gap: 1rem; margin-top: 1.25rem; }
  .footer__social-link { color: rgba(245,241,233,0.55); transition: color var(--ff-transition); }
  .footer__social-link:hover { color: var(--ff-sage-lt); }
  .footer__column .footer__list { margin: 0; padding: 0; }
  .footer__list-item { margin-bottom: 0.6rem; }
  .footer__newsletter-form { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .footer__newsletter-input { flex: 1; min-width: 0; padding: 0.6rem 0.875rem; }
  .footer__newsletter-btn { flex-shrink: 0; padding: 0.6rem 1.25rem !important; font-size: 0.72rem !important; }
  .footer__policy-row {
    display: flex; flex-wrap: wrap; gap: 0.5rem 1.5rem;
    border-top: 1px solid rgba(245,241,233,0.1);
    padding-top: 1.5rem; margin-top: 3rem;
  }
  .footer__policy-row a {
    font-size: 0.72rem; color: rgba(245,241,233,0.45);
    text-decoration: none; letter-spacing: 0.05em;
    transition: color var(--ff-transition);
  }
  .footer__policy-row a:hover { color: var(--ff-sage-lt); }
  .footer__bottom {
    display: flex; justify-content: space-between; align-items: center;
    border-top: 1px solid rgba(245,241,233,0.1);
    padding-top: 1.5rem; margin-top: 3rem;
    font-size: 0.72rem; color: rgba(245,241,233,0.35); letter-spacing: 0.06em;
  }
  .footer__bottom p { margin: 0; }
  .footer__payments { display: flex; gap: 0.5rem; align-items: center; }
  .footer__payment-icon { height: 20px; opacity: 0.5; }
  @media (max-width: 989px) {
    .footer__grid { grid-template-columns: repeat(2, 1fr); }
    .footer__brand { grid-column: 1 / -1; }
  }
  @media (max-width: 749px) {
    .footer__grid { grid-template-columns: 1fr; gap: 2rem; }
    .footer__bottom { flex-direction: column; gap: 1rem; text-align: center; }
  }
</style>

{% schema %}
{
  "name": "Footer",
  "limit": 1,
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer logo (will be inverted to white)"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Strength in everyday."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Brand description",
      "default": "Considered pieces chosen for form as much as function."
    },
    {
      "type": "url",
      "id": "instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "tiktok",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "facebook",
      "label": "Facebook URL"
    },
    {
      "type": "text",
      "id": "heading_1",
      "label": "Column 1 heading",
      "default": "Shop"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "Column 1 menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "heading_2",
      "label": "Column 2 heading",
      "default": "Help"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Column 2 menu",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "heading_3",
      "label": "Column 3 heading"
    },
    {
      "type": "link_list",
      "id": "menu_3",
      "label": "Column 3 menu"
    }
  ]
}
{% endschema %}
