<section class="slideshow" data-slideshow data-autoplay="{{ section.settings.autoplay_speed | times: 1000 }}" aria-label="Hero slideshow" style="--slideshow-height: {{ section.settings.height }}px;">
  {%- for block in section.blocks -%}
    <div class="slideshow__slide{% if forloop.first %} is-active{% endif %}" data-slide {{ block.shopify_attributes }}>
      <div class="slideshow__media">
        {%- if block.settings.image -%}
          <img
            src="{{ block.settings.image | image_url: width: 2000 }}"
            srcset="{{ block.settings.image | image_url: width: 750 }} 750w, {{ block.settings.image | image_url: width: 1500 }} 1500w, {{ block.settings.image | image_url: width: 2400 }} 2400w"
            sizes="100vw"
            alt="{{ block.settings.image.alt | escape | default: block.settings.heading | escape }}"
            loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
            {% if forloop.first %}fetchpriority="high"{% endif %}
            class="slideshow__image"
          >
        {%- else -%}
          {%- assign slide_index = forloop.index0 -%}
          {%- if slide_index == 0 -%}
            <img src="https://cdn.shopify.com/s/files/1/0733/9887/8359/files/photo-1534438327276-14e5300c3a48.jpg?v=1780233201" alt="{{ block.settings.heading | escape }}" loading="eager" fetchpriority="high" class="slideshow__image">
          {%- elsif slide_index == 1 -%}
            <img src="https://cdn.shopify.com/s/files/1/0733/9887/8359/files/photo-1571019614242-c5c5dee9f50b.jpg?v=1780233201" alt="{{ block.settings.heading | escape }}" loading="lazy" class="slideshow__image">
          {%- elsif slide_index == 2 -%}
            <img src="https://cdn.shopify.com/s/files/1/0733/9887/8359/files/photo-1518611012118-696072aa579a.jpg?v=1780233201" alt="{{ block.settings.heading | escape }}" loading="lazy" class="slideshow__image">
          {%- else -%}
            {%- assign fb = collections[block.settings.collection] | default: collections['shop-all'] -%}
            {%- if fb.image -%}
              <img src="{{ fb.image | image_url: width: 2000 }}" alt="{{ block.settings.heading | escape }}" loading="lazy" class="slideshow__image">
            {%- else -%}
              <div class="slideshow__placeholder"></div>
            {%- endif -%}
          {%- endif -%}
        {%- endif -%}
        <span class="slideshow__overlay" style="opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};"></span>
      </div>

      <div class="slideshow__content slideshow__content--{{ block.settings.position }} slideshow__content--bottom">
        <div class="slideshow__box slideshow__box--bare">
          {%- if block.settings.eyebrow != blank -%}<p class="eyebrow slideshow__eyebrow">{{ block.settings.eyebrow | escape }}</p>{%- endif -%}
          {%- if block.settings.heading != blank -%}<h2 class="slideshow__heading">{{ block.settings.heading | escape }}</h2>{%- endif -%}
          {%- if block.settings.subtext != blank -%}<p class="slideshow__subtext">{{ block.settings.subtext | escape }}</p>{%- endif -%}
          {%- if block.settings.button_label != blank -%}
            <a href="{{ block.settings.button_link | default: '#' }}" class="button slideshow__button">{{ block.settings.button_label | escape }}</a>
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- endfor -%}

  {%- if section.blocks.size > 1 -%}
    <button class="slideshow__arrow slideshow__arrow--prev" data-slide-prev aria-label="Previous slide">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 18l-6-6 6-6"/></svg>
    </button>
    <button class="slideshow__arrow slideshow__arrow--next" data-slide-next aria-label="Next slide">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"/></svg>
    </button>
    <div class="slideshow__dots">
      {%- for block in section.blocks -%}
        <button class="slideshow__dot{% if forloop.first %} is-active{% endif %}" data-slide-dot aria-label="Go to slide {{ forloop.index }}"></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

<style>
  .slideshow { position: relative; height: var(--slideshow-height, 650px); overflow: hidden; background: #3a3f40; }
  .slideshow__slide {
    position: absolute; top: 0; right: 0; bottom: 0; left: 0; display: flex; align-items: center;
    opacity: 0; visibility: hidden; transition: opacity 0.7s ease;
  }
  .slideshow__slide.is-active { opacity: 1; visibility: visible; z-index: 1; }
  .slideshow__media { position: absolute; top: 0; right: 0; bottom: 0; left: 0; }
  .slideshow__image {
    position: absolute; top: 0; right: 0; bottom: 0; left: 0; width: 100%; height: 100%;
    object-fit: cover; object-position: center;
  }
  .slideshow__placeholder { position: absolute; top: 0; right: 0; bottom: 0; left: 0; background: linear-gradient(135deg, #3a3f40, #6B6F70); }
  /* Even vignette — darkens edges, leaves centre bright */
  .slideshow__overlay {
    position: absolute; top: 0; right: 0; bottom: 0; left: 0;
    background: rgba(0,0,0,0.18);
  }
  .slideshow__content { position: relative; z-index: 2; width: 100%; padding: 0 2.5rem; display: flex; }
  /* Bottom-up scrim: keeps bottom-aligned hero copy legible over any image */
  .slideshow__content--bottom::before {
    content: ''; position: absolute; left: 0; right: 0; bottom: 0; height: 70%;
    background: linear-gradient(to top, rgba(38,48,40,0.55), transparent 45%);
    pointer-events: none; z-index: -1;
  }
  .slideshow__content--left { justify-content: flex-start; }
  .slideshow__content--center { justify-content: center; text-align: center; }
  .slideshow__content--right { justify-content: flex-end; }
  .slideshow__box { background: rgba(245,241,233,0.92); -webkit-backdrop-filter: blur(4px); backdrop-filter: blur(4px); padding: 2.5rem 3rem; max-width: 560px; border-radius: var(--ff-radius-lg); }
  .slideshow__content--center .slideshow__box { text-align: center; }
  .slideshow__heading { font-size: clamp(2.25rem, 5vw, 4rem) !important; margin: 0.4rem 0; line-height: 1.05; }
  .slideshow__subtext { font-size: 1rem; color: var(--ff-charcoal-80); margin: 0.5rem 0 1.5rem; }
  /* Arrows */
  .slideshow__arrow {
    position: absolute; top: 50%; transform: translateY(-50%); z-index: 3;
    width: 44px; height: 44px; border-radius: 50%; border: none; cursor: pointer;
    background: rgba(245,241,233,0.85); color: var(--ff-charcoal);
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s ease; opacity: 0.85;
  }
  .slideshow__arrow:hover { background: var(--ff-cream); opacity: 1; }
  .slideshow__arrow--prev { left: 1.25rem; }
  .slideshow__arrow--next { right: 1.25rem; }
  /* Dots */
  .slideshow__dots { position: absolute; bottom: 1.5rem; left: 0; right: 0; z-index: 3; display: flex; justify-content: center; gap: 0.5rem; }
  .slideshow__dot { width: 9px; height: 9px; border-radius: 50%; border: none; cursor: pointer; background: rgba(245,241,233,0.55); transition: background 0.2s, width 0.2s; padding: 0; }
  .slideshow__dot.is-active { background: var(--ff-cream); width: 24px; border-radius: 99px; }
  @media (max-width: 749px) {
    .slideshow { height: auto; min-height: 460px; }
    .slideshow__slide { position: relative; height: 460px; }
    .slideshow__slide:not(.is-active) { display: none; }
    .slideshow__box { padding: 1.5rem; max-width: 100%; }
    .slideshow__content { padding: 0 1rem; }
    .slideshow__arrow { width: 36px; height: 36px; }
    .slideshow__arrow--prev { left: 0.5rem; }
    .slideshow__arrow--next { right: 0.5rem; }
  }
</style>

{% schema %}
{
  "name": "Hero slideshow",
  "max_blocks": 5,
  "settings": [
    { "type": "range", "id": "height", "min": 400, "max": 900, "step": 50, "unit": "px", "label": "Slide height", "default": 650 },
    { "type": "range", "id": "autoplay_speed", "min": 0, "max": 10, "step": 1, "unit": "s", "label": "Autoplay speed (0 = off)", "default": 6 }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "collection", "id": "collection", "label": "Fallback image from collection", "info": "Used until you upload an image above" },
        { "type": "range", "id": "overlay_opacity", "min": 0, "max": 70, "step": 5, "unit": "%", "label": "Image overlay", "default": 25 },
        { "type": "select", "id": "position", "label": "Content position", "options": [
          { "value": "left", "label": "Left" }, { "value": "center", "label": "Centre" }, { "value": "right", "label": "Right" }
        ], "default": "left" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Strength in Everyday." },
        { "type": "textarea", "id": "subtext", "label": "Subtext" },
        { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop now" },
        { "type": "url", "id": "button_link", "label": "Button link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero slideshow",
      "blocks": [ { "type": "slide" }, { "type": "slide" } ]
    }
  ]
}
{% endschema %}
