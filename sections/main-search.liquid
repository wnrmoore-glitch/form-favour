<div class="search-page section">
  <div class="page-width">
    <h1 class="search-page__title">Search</h1>
    {%- form 'search', action: routes.search_url -%}
      <div class="search-page__form">
        <input
          type="search" name="q"
          value="{{ search.terms | escape }}"
          placeholder="Search products…"
          class="field__input search-page__input"
          aria-label="Search"
        >
        <button type="submit" class="button">Search</button>
      </div>
    {%- endform -%}
    {%- if search.performed -%}
      {%- if search.results_count == 0 -%}
        <p class="search-page__empty">No results for <em>"{{ search.terms | escape }}"</em>.</p>
      {%- else -%}
        <p class="search-page__count">{{ search.results_count }} result{% if search.results_count != 1 %}s{% endif %} for <em>"{{ search.terms | escape }}"</em></p>
        <ul class="product-grid product-grid--4-col list-unstyled" role="list">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              <li class="product-grid__item">
                {%- render 'product-card', product: item -%}
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
    {%- endif -%}
  </div>
</div>
<style>
  .search-page__title { margin-bottom: 1.5rem; }
  .search-page__form { display: flex; gap: 0.75rem; margin-bottom: 2.5rem; max-width: 560px; }
  .search-page__input { flex: 1; }
  .search-page__count, .search-page__empty { color: var(--ff-stone); margin-bottom: 1.5rem; }
</style>
{% schema %}
{ "name": "Search", "settings": [] }
{% endschema %}
