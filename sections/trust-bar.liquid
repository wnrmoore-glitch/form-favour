{%- assign items = '' -%}
<div class="trust-bar trust-bar--marquee">
  <div class="trust-bar__marquee-track" aria-hidden="true">
    {%- comment -%} Render twice for seamless loop {%- endcomment -%}
    {%- for pass in (1..2) -%}
      <div class="trust-bar__marquee-inner">
        {%- for i in (1..4) -%}
          {%- assign icon_key = 'icon_' | append: i -%}
          {%- assign text_key = 'text_' | append: i -%}
          {%- if section.settings[text_key] != blank -%}
            <span class="trust-bar__marquee-item">
              {%- case section.settings[icon_key] -%}
                {%- when 'shipping' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                {%- when 'lock' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                {%- when 'return' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.91"/></svg>
                {%- when 'star' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                {%- else -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="20 6 9 17 4 12"/></svg>
              {%- endcase -%}
              {{ section.settings[text_key] | escape }}
            </span>
            <span class="trust-bar__marquee-sep" aria-hidden="true">✦</span>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Trust bar",
  "settings": [
    { "type": "select", "id": "icon_1", "label": "Icon 1", "options": [{"value":"shipping","label":"Shipping"},{"value":"lock","label":"Lock / Secure"},{"value":"return","label":"Returns"},{"value":"star","label":"Star"},{"value":"check","label":"Check"}], "default": "shipping" },
    { "type": "text", "id": "text_1", "label": "Text 1", "default": "Free UK shipping over £50" },
    { "type": "select", "id": "icon_2", "label": "Icon 2", "options": [{"value":"shipping","label":"Shipping"},{"value":"lock","label":"Lock / Secure"},{"value":"return","label":"Returns"},{"value":"star","label":"Star"},{"value":"check","label":"Check"}], "default": "lock" },
    { "type": "text", "id": "text_2", "label": "Text 2", "default": "Secure checkout" },
    { "type": "select", "id": "icon_3", "label": "Icon 3", "options": [{"value":"shipping","label":"Shipping"},{"value":"lock","label":"Lock / Secure"},{"value":"return","label":"Returns"},{"value":"star","label":"Star"},{"value":"check","label":"Check"}], "default": "return" },
    { "type": "text", "id": "text_3", "label": "Text 3", "default": "Easy 30-day returns" },
    { "type": "select", "id": "icon_4", "label": "Icon 4", "options": [{"value":"shipping","label":"Shipping"},{"value":"lock","label":"Lock / Secure"},{"value":"return","label":"Returns"},{"value":"star","label":"Star"},{"value":"check","label":"Check"}], "default": "star" },
    { "type": "text", "id": "text_4", "label": "Text 4", "default": "Trusted by thousands" }
  ],
  "presets": [{ "name": "Trust bar" }]
}
{% endschema %}
