{%- paginate collection.products by 48 -%}
{%- render 'breadcrumbs' -%}
<div class="collection-page section">
  <div class="page-width">
    <!-- Collection header -->
    <div class="collection-header">
      <h1 class="collection__title">{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <div class="collection__description rte">{{ collection.description }}</div>
      {%- endif -%}
    </div>

    <!-- Results count + sort + column picker -->
    <div class="collection-toolbar">
      <p class="collection-toolbar__count">
        {{ collection.products_count }} product{% if collection.products_count != 1 %}s{% endif %}
      </p>
      <div class="collection-toolbar__right">
        <!-- Column picker -->
        <div class="col-picker" aria-label="Products per row">
          {%- assign cols = '3,4,5,6' | split: ',' -%}
          {%- for c in cols -%}
            <button
              class="col-picker__btn{% if c == section.settings.columns_desktop %} col-picker__btn--active{% endif %}"
              data-cols="{{ c }}"
              aria-label="{{ c }} per row"
              aria-pressed="{% if c == section.settings.columns_desktop %}true{% else %}false{% endif %}"
            >{{ c }}</button>
          {%- endfor -%}
        </div>
        <!-- Sort -->
        <div class="collection-toolbar__sort">
          <label for="sort-by" class="sr-only">Sort by</label>
          {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
          <select name="sort_by" id="sort-by" class="select__select" onchange="location.search='?sort_by='+this.value">
            {%- for option in collection.sort_options -%}
              <option value="{{ option.value }}"{% if option.value == sort_by %} selected{% endif %}>
                {{ option.name }}
              </option>
            {%- endfor -%}
          </select>
        </div>
      </div>
    </div>

    <!-- Product grid -->
    {%- if collection.products.size > 0 -%}
      <ul
        id="product-grid"
        class="product-grid list-unstyled"
        role="list"
        style="--grid-cols: {{ section.settings.columns_desktop }};"
      >
        {%- for product in collection.products -%}
          <li class="product-grid__item">
            {%- render 'product-card', product: product -%}
          </li>
        {%- endfor -%}
      </ul>

      <!-- Pagination -->
      {%- if paginate.pages > 1 -%}
        <nav class="pagination" aria-label="Pagination">
          <ul class="pagination__list list-unstyled" role="list">
            {%- if paginate.previous -%}
              <li><a href="{{ paginate.previous.url }}" class="pagination__item">‹ Prev</a></li>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <li><a href="{{ part.url }}" class="pagination__item">{{ part.title }}</a></li>
              {%- else -%}
                <li><span class="pagination__item pagination__item--current" aria-current="page">{{ part.title }}</span></li>
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <li><a href="{{ paginate.next.url }}" class="pagination__item">Next ›</a></li>
            {%- endif -%}
          </ul>
        </nav>
      {%- endif -%}
    {%- else -%}
      <p class="collection-empty">No products found in this collection.</p>
    {%- endif -%}
  </div>
</div>
{%- endpaginate -%}

<style>
  .collection-header { text-align: center; margin-bottom: 2rem; }
  .collection__title { margin: 0 0 0.5rem; }
  .collection__description { color: var(--ff-stone); max-width: 600px; margin: 0 auto; }

  .collection-toolbar {
    display: flex; justify-content: space-between; align-items: center;
    padding: 0.75rem 0; border-top: var(--ff-border); border-bottom: var(--ff-border);
    margin-bottom: 1.5rem; gap: 1rem;
  }
  .collection-toolbar__count { font-size: 0.78rem; color: var(--ff-stone); letter-spacing: 0.06em; margin: 0; }
  .collection-toolbar__right { display: flex; align-items: center; gap: 1rem; }
  .collection-toolbar__sort select { font-size: 0.8rem; }

  /* Column picker */
  .col-picker { display: flex; gap: 0.25rem; }
  .col-picker__btn {
    width: 30px; height: 30px;
    background: none; border: var(--ff-border); border-radius: var(--ff-radius);
    font-size: 0.75rem; font-family: var(--ff-font-body); color: var(--ff-stone);
    cursor: pointer; transition: all var(--ff-transition);
    display: flex; align-items: center; justify-content: center;
  }
  .col-picker__btn:hover { border-color: var(--ff-charcoal); color: var(--ff-charcoal); }
  .col-picker__btn--active {
    background: var(--ff-charcoal); border-color: var(--ff-charcoal); color: var(--ff-cream);
  }

  /* Product grid */
  .product-grid {
    display: grid;
    grid-template-columns: repeat(var(--grid-cols, 4), 1fr);
    gap: 1.25rem;
    margin: 0; padding: 0;
  }
  .product-grid__item { min-width: 0; }

  /* Responsive breakpoints */
  @media (max-width: 1024px) {
    .product-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 749px) {
    .product-grid { grid-template-columns: repeat(2, 1fr); gap: 0.75rem; }
    .col-picker { display: none; }
  }

  .pagination { margin-top: 2.5rem; }
  .pagination__list { display: flex; justify-content: center; gap: 0.5rem; flex-wrap: wrap; margin: 0; padding: 0; }
  .pagination__item {
    display: flex; align-items: center; justify-content: center;
    min-width: 40px; height: 40px; padding: 0 0.75rem;
    border: var(--ff-border); border-radius: var(--ff-radius);
    text-decoration: none; font-size: 0.85rem; color: var(--ff-charcoal);
    transition: background-color var(--ff-transition), color var(--ff-transition);
  }
  .pagination__item:hover,
  .pagination__item--current {
    background: var(--ff-charcoal); border-color: var(--ff-charcoal); color: var(--ff-cream);
  }
  .collection-empty { text-align: center; color: var(--ff-stone); padding: 3rem 0; }
  .sr-only { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; }
</style>

<script>
(function () {
  var grid = document.getElementById('product-grid');
  if (!grid) return;
  document.querySelectorAll('.col-picker__btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var cols = btn.dataset.cols;
      grid.style.setProperty('--grid-cols', cols);
      document.querySelectorAll('.col-picker__btn').forEach(function (b) {
        b.classList.toggle('col-picker__btn--active', b === btn);
        b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
      });
    });
  });
})();
</script>

{% schema %}
{
  "name": "Collection products",
  "settings": [
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Default columns on desktop",
      "options": [
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" },
        { "value": "6", "label": "6" }
      ],
      "default": "4"
    }
  ]
}
{% endschema %}
