<section class="collection-list section">
  <div class="page-width">
    {%- if section.settings.title != blank -%}
      <div class="section__header text-center">
        {%- if section.settings.eyebrow != blank -%}
          <p class="eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        <h2>{{ section.settings.title | escape }}</h2>
      </div>
    {%- endif -%}

    <div class="collection-list__grid">
      {%- for block in section.blocks -%}
        {%- assign coll = collections[block.settings.collection] -%}
        {%- if coll != blank -%}
          <a href="{{ coll.url }}" class="collection-tile" {{ block.shopify_attributes }}>
            <div class="collection-tile__media">
              {%- if coll.image -%}
                <img
                  src="{{ coll.image | image_url: width: 700 }}"
                  srcset="{{ coll.image | image_url: width: 500 }} 500w, {{ coll.image | image_url: width: 800 }} 800w"
                  sizes="(max-width: 749px) 100vw, 33vw"
                  alt="{{ coll.title | escape }}"
                  width="{{ coll.image.width }}" height="{{ coll.image.height }}"
                  loading="lazy"
                >
              {%- elsif coll.products.first.featured_image -%}
                <img
                  src="{{ coll.products.first.featured_image | image_url: width: 700 }}"
                  alt="{{ coll.title | escape }}" loading="lazy"
                >
              {%- else -%}
                <div class="collection-tile__placeholder"></div>
              {%- endif -%}
              <span class="collection-tile__overlay"></span>
            </div>
            <div class="collection-tile__content">
              <h3 class="collection-tile__title">{{ block.settings.heading | default: coll.title | escape }}</h3>
              <span class="collection-tile__cta">Shop now →</span>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .collection-list__grid {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size | at_most: 3 }}, 1fr);
    gap: 1.5rem;
  }
  .collection-tile {
    position: relative; display: block; text-decoration: none;
    border-radius: var(--ff-radius-lg); overflow: hidden;
    aspect-ratio: 4/5; background: var(--ff-cream-dk);
  }
  .collection-tile__media { position: absolute; top: 0; right: 0; bottom: 0; left: 0; }
  .collection-tile__media img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
  .collection-tile:hover .collection-tile__media img { transform: scale(1.05); }
  .collection-tile__placeholder { width: 100%; height: 100%; background: linear-gradient(135deg, var(--ff-charcoal), var(--ff-stone)); }
  .collection-tile__overlay {
    position: absolute; top: 0; right: 0; bottom: 0; left: 0;
    background: linear-gradient(to top, rgba(38,41,42,0.65) 0%, rgba(38,41,42,0.1) 50%, transparent 100%);
  }
  .collection-tile__content {
    position: absolute; left: 0; right: 0; bottom: 0;
    padding: 1.75rem; color: var(--ff-cream);
  }
  .collection-tile__title {
    font-family: var(--ff-font-heading) !important;
    color: var(--ff-cream) !important;
    font-size: 1.5rem; margin: 0 0 0.25rem;
  }
  .collection-tile__cta {
    font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--ff-cream); opacity: 0.85;
    transition: letter-spacing 0.3s ease;
  }
  .collection-tile:hover .collection-tile__cta { letter-spacing: 0.2em; }
  @media (max-width: 749px) {
    .collection-list__grid { grid-template-columns: 1fr; }
    .collection-tile { aspect-ratio: 16/10; }
  }
</style>

{% schema %}
{
  "name": "Collection list",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Browse" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Shop by category" }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "text", "id": "heading", "label": "Custom heading (optional)" }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Collection list",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
