<header class="header" role="banner">
  <div class="header__inner page-width">

    <!-- Mobile hamburger -->
    <button class="header__icon header__icon--menu js-menu-open" aria-label="Open menu" aria-expanded="false">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>

    <!-- Logo -->
    <a href="/" class="header__logo-link" aria-label="{{ shop.name }}">
      {%- if section.settings.logo -%}
        <img
          src="{{ section.settings.logo | image_url: width: 360 }}"
          alt="{{ shop.name }}"
          width="{{ section.settings.logo_width }}"
          height="{{ section.settings.logo_width | divided_by: section.settings.logo.aspect_ratio | round }}"
          loading="eager"
          class="header__logo"
        >
      {%- else -%}
        <img
          src="https://cdn.shopify.com/s/files/1/0733/9887/8359/files/form-and-favour-logo-transparent.png?v=1780190020"
          alt="{{ shop.name }}"
          width="{{ section.settings.logo_width }}"
          height="{{ section.settings.logo_width | divided_by: 2.667 | round }}"
          loading="eager"
          class="header__logo"
        >
      {%- endif -%}
    </a>

    <!-- Desktop nav -->
    <nav class="header__nav" aria-label="Main navigation">
      <ul class="header__nav-list list-unstyled" role="list">
        {%- for link in section.settings.menu.links -%}
          <li class="header__nav-item{% if link.active %} header__nav-item--active{% endif %}">
            {%- if link.links != blank -%}
              <button class="header__menu-item" aria-expanded="false" aria-haspopup="true">
                {{ link.title | escape }}
                <svg width="10" height="6" viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 1l4 4 4-4"/></svg>
              </button>
              <ul class="header__submenu list-unstyled" role="list">
                {%- for child in link.links -%}
                  <li><a href="{{ child.url }}" class="header__submenu-link">{{ child.title | escape }}</a></li>
                {%- endfor -%}
              </ul>
            {%- else -%}
              <a href="{{ link.url }}" class="header__menu-item"{% if link.active %} aria-current="page"{% endif %}>
                {{ link.title | escape }}
              </a>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </nav>

    <!-- Icons -->
    <div class="header__icons">
      <!-- Search -->
      <button class="header__icon" aria-label="Search" data-search-open type="button">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      </button>
      <!-- Account -->
      {%- if shop.customer_accounts_enabled -%}
        <a href="{%- if customer -%}/account{%- else -%}/account/login{%- endif -%}" class="header__icon" aria-label="Account">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </a>
      {%- endif -%}
      <!-- Cart -->
      <a href="/cart" class="header__icon header__icon--cart" aria-label="Cart ({{ cart.item_count }} items)" data-cart-open>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        {%- if cart.item_count > 0 -%}
          <span class="cart-count-bubble js-cart-count">{{ cart.item_count }}</span>
        {%- else -%}
          <span class="cart-count-bubble js-cart-count" style="display:none">0</span>
        {%- endif -%}
      </a>
    </div>

  </div><!-- /.header__inner -->

  <!-- Mobile nav drawer -->
  <div class="mobile-nav js-mobile-nav" aria-hidden="true">
    <div class="mobile-nav__overlay js-menu-close"></div>
    <nav class="mobile-nav__panel">
      <button class="mobile-nav__close js-menu-close" aria-label="Close menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <ul class="mobile-nav__list list-unstyled" role="list">
        {%- for link in section.settings.menu.links -%}
          <li class="mobile-nav__item">
            <a href="{{ link.url }}" class="mobile-nav__link">{{ link.title | escape }}</a>
            {%- if link.links != blank -%}
              <ul class="mobile-nav__sub list-unstyled">
                {%- for child in link.links -%}
                  <li><a href="{{ child.url }}" class="mobile-nav__sub-link">{{ child.title | escape }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </nav>
  </div>

  <!-- Predictive search overlay -->
  <div class="search-overlay" data-search-overlay aria-hidden="true">
    <div class="search-overlay__backdrop" data-search-close></div>
    <div class="search-overlay__panel" data-predictive-search>
      <form action="/search" method="get" role="search" class="search-overlay__form">
        <svg class="search-overlay__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input type="search" name="q" placeholder="Search products…" autocomplete="off" aria-label="Search">
        <button type="button" class="search-overlay__close" data-search-close aria-label="Close search">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </form>
      <div class="predictive__results" data-predictive-results></div>
    </div>
  </div>

</header>

<style>
  /* Header layout */
  .header__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 2rem;
    padding-top: 1rem;
    padding-bottom: 1rem;
  }
  .header__logo { height: auto; }
  .header__logo-text { font-size: 1.4rem; letter-spacing: 0.1em; }
  .header__nav { justify-self: center; }
  .header__nav-list { display: flex; gap: 2.5rem; margin: 0; padding: 0; }
  .header__icons { display: flex; align-items: center; gap: 1.25rem; justify-self: end; }
  .header__icon { position: relative; color: var(--ff-charcoal); display: flex; align-items: center; }
  .cart-count-bubble {
    position: absolute; top: -6px; right: -8px;
    width: 18px; height: 18px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.6rem; font-weight: 600;
  }
  /* Dropdown */
  .header__nav-item { position: relative; }
  .header__submenu {
    position: absolute; top: calc(100% + 0.75rem); left: 0;
    min-width: 180px; padding: 0.5rem 0;
    opacity: 0; visibility: hidden; transform: translateY(4px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 200;
  }
  .header__nav-item:hover .header__submenu,
  .header__nav-item:focus-within .header__submenu {
    opacity: 1; visibility: visible; transform: translateY(0);
  }
  .header__submenu-link {
    display: block; padding: 0.5rem 1.25rem;
    font-size: 0.82rem; color: var(--ff-charcoal) !important;
    text-decoration: none; transition: color 0.2s;
  }
  .header__submenu-link:hover { color: var(--ff-sage) !important; }
  /* Mobile nav */
  .header__icon--menu { display: none; background: none; border: none; cursor: pointer; padding: 0; }
  .mobile-nav { display: none; }
  @media (max-width: 749px) {
    .header__icon--menu { display: flex; }
    .header__nav { display: none; }
    .header__inner { grid-template-columns: auto 1fr auto; }
    .mobile-nav {
      display: block; position: fixed; top: 0; right: 0; bottom: 0; left: 0; z-index: 300;
      pointer-events: none;
    }
    .mobile-nav[aria-hidden="false"] { pointer-events: all; }
    .mobile-nav__overlay {
      position: absolute; top: 0; right: 0; bottom: 0; left: 0;
      background: rgba(38,41,42,0.5);
      opacity: 0; transition: opacity 0.3s;
    }
    .mobile-nav[aria-hidden="false"] .mobile-nav__overlay { opacity: 1; }
    .mobile-nav__panel {
      position: absolute; top: 0; left: 0; bottom: 0;
      width: 80vw; max-width: 320px;
      background: var(--ff-cream); padding: 1.5rem;
      transform: translateX(-100%); transition: transform 0.3s ease;
    }
    .mobile-nav[aria-hidden="false"] .mobile-nav__panel { transform: translateX(0); }
    .mobile-nav__close {
      background: none; border: none; cursor: pointer;
      margin-left: auto; display: block; margin-bottom: 1.5rem;
    }
    .mobile-nav__list { margin: 0; padding: 0; }
    .mobile-nav__link {
      display: block; padding: 0.9rem 0; border-bottom: var(--ff-border);
      font-size: 1rem; text-decoration: none; color: var(--ff-charcoal);
      letter-spacing: 0.06em;
    }
    .mobile-nav__sub { padding-left: 1rem; }
    .mobile-nav__sub-link {
      display: block; padding: 0.5rem 0;
      font-size: 0.85rem; color: var(--ff-stone); text-decoration: none;
    }
  }
</style>

<script>
  (function () {
    var openBtns = document.querySelectorAll('.js-menu-open');
    var closeBtns = document.querySelectorAll('.js-menu-close');
    var nav = document.querySelector('.js-mobile-nav');
    function open() { nav.setAttribute('aria-hidden', 'false'); document.body.style.overflow = 'hidden'; }
    function close() { nav.setAttribute('aria-hidden', 'true'); document.body.style.overflow = ''; }
    openBtns.forEach(function(b){ b.addEventListener('click', open); });
    closeBtns.forEach(function(b){ b.addEventListener('click', close); });
  })();
</script>

{% schema %}
{
  "name": "Header",
  "limit": 1,
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 100,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 180
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
