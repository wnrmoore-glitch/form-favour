{% comment %} Recently viewed products — JS-powered, stores up to 8 handles in localStorage {% endcomment %}
<section class="recently-viewed page-width section" id="recently-viewed" style="display:none">
  <div class="section__header text-center">
    <p class="eyebrow">Your history</p>
    <h2>Recently viewed</h2>
  </div>
  <div class="product-grid product-grid--4" id="recently-viewed-grid"></div>
</section>

<script>
(function () {
  var KEY = 'ff-recently-viewed';
  var MAX = 8;
  var currentHandle = {{ product.handle | json }};

  // Save current product
  var viewed = JSON.parse(localStorage.getItem(KEY) || '[]');
  viewed = viewed.filter(function (h) { return h !== currentHandle; });
  viewed.unshift(currentHandle);
  if (viewed.length > MAX) viewed = viewed.slice(0, MAX);
  localStorage.setItem(KEY, JSON.stringify(viewed));

  // Render others
  var others = viewed.filter(function (h) { return h !== currentHandle; }).slice(0, 4);
  if (!others.length) return;

  var section = document.getElementById('recently-viewed');
  var grid = document.getElementById('recently-viewed-grid');
  if (!section || !grid) return;

  var fetched = 0;
  others.forEach(function (handle) {
    fetch('/products/' + handle + '.js')
      .then(function (r) { return r.json(); })
      .then(function (p) {
        var img = p.featured_image ? p.featured_image.replace(/(\.[a-z]+)(\?|$)/i, '_400x400$1$2') : '';
        var price = p.price_min ? ('£' + (p.price_min / 100).toFixed(2)) : '';
        var card = '<div class="card"><a href="/products/' + p.handle + '" class="card__link">'
          + '<div class="card__media">' + (img ? '<img src="' + img + '" alt="' + p.title + '" loading="lazy">' : '') + '</div>'
          + '<div class="card-information"><h3 class="card__heading">' + p.title + '</h3>'
          + '<div class="card__price"><span class="price">' + price + '</span></div></div>'
          + '</a></div>';
        grid.insertAdjacentHTML('beforeend', card);
        fetched++;
        if (fetched === others.length) section.style.display = 'block';
      }).catch(function () {});
  });
})();
</script>
