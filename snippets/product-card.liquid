{% comment %}
  Renders a product card.
  Usage: {% render 'product-card', product: product %}
{% endcomment %}

{%- assign first_image = product.featured_image -%}
{%- assign second_image = product.images[1] -%}

<div class="card" itemscope itemtype="http://schema.org/Product">
  <div class="card__media">
    {%- if first_image -%}
      <img
        src="{{ first_image | image_url: width: 600 }}"
        srcset="{{ first_image | image_url: width: 400 }} 400w,
                {{ first_image | image_url: width: 600 }} 600w,
                {{ first_image | image_url: width: 800 }} 800w"
        sizes="(max-width: 749px) 50vw, (max-width: 1024px) 33vw, 20vw"
        alt="{{ first_image.alt | escape | default: product.title | escape }}"
        width="{{ first_image.width }}"
        height="{{ first_image.height }}"
        loading="lazy"
        itemprop="image"
      >
      {%- if second_image -%}
        <img
          class="card__media-secondary"
          src="{{ second_image | image_url: width: 600 }}"
          srcset="{{ second_image | image_url: width: 400 }} 400w,
                  {{ second_image | image_url: width: 600 }} 600w,
                  {{ second_image | image_url: width: 800 }} 800w"
          sizes="(max-width: 749px) 50vw, (max-width: 1024px) 33vw, 20vw"
          alt="{{ second_image.alt | escape | default: product.title | escape }}"
          width="{{ second_image.width }}"
          height="{{ second_image.height }}"
          loading="lazy"
          aria-hidden="true"
        >
      {%- endif -%}
    {%- else -%}
      <div class="card__media-placeholder">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
      </div>
    {%- endif -%}

    <!-- Sale badge -->
    {%- if product.compare_at_price > product.price -%}
      <span class="badge badge--sale">Sale</span>
    {%- endif -%}
    {%- unless product.available -%}
      <span class="badge badge--sold-out">Sold out</span>
    {%- endunless -%}

    <!-- Wishlist heart -->
    <button
      type="button"
      class="card__wishlist js-wishlist-btn"
      data-handle="{{ product.handle }}"
      data-title="{{ product.title | escape }}"
      data-price="{{ product.price | money }}"
      data-image="{{ product.featured_image | image_url: width: 120 }}"
      aria-label="Save to wishlist"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
    </button>

    <!-- Quick add overlays the photo -->
    {%- assign first_available = product.variants | where: 'available', true | first -%}
    {%- if first_available -%}
      {%- if product.variants.size == 1 -%}
        <button type="button" class="quick-add-btn" data-quick-add data-variant-id="{{ first_available.id }}">Quick add</button>
      {%- else -%}
        <a href="{{ product.url }}" class="quick-add-btn" aria-label="Choose options for {{ product.title | escape }}">Choose options</a>
      {%- endif -%}
    {%- endif -%}
  </div>

  <div class="card-information">
    {%- if product.vendor != blank -%}
      <p class="card__vendor">{{ product.vendor | escape }}</p>
    {%- endif -%}
    <h3 class="card__heading">
      <a href="{{ product.url }}" class="card__link" itemprop="name">{{ product.title | escape }}</a>
    </h3>
    <div class="card__stars jdgm-widget jdgm-preview-badge" data-id="{{ product.id }}">
      {{ product.metafields.judgeme.badge }}
    </div>
    <div class="card__price">
      {%- if product.compare_at_price > product.price -%}
        <span class="price price--on-sale">
          <span class="price-item price-item--sale">{{ product.price | money }}</span>
          <span class="price-item price-item--regular">{{ product.compare_at_price | money }}</span>
        </span>
      {%- else -%}
        <span class="price">{{ product.price | money }}</span>
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  .card {
    position: relative;
    background: var(--ff-white);
    border-radius: var(--ff-radius-lg);
    overflow: hidden;
    border: 1px solid rgba(38, 48, 40, 0.06);
    box-shadow: 0 1px 2px rgba(38, 48, 40, 0.04);
    transition: box-shadow 0.3s ease, transform 0.3s ease, border-color 0.3s ease;
  }
  .card:hover {
    box-shadow: 0 14px 34px rgba(38, 48, 40, 0.13);
    transform: translateY(-4px);
    border-color: rgba(38, 48, 40, 0.1);
  }
  /* Title link stretches over the whole card so the card is clickable —
     interactive controls (wishlist, quick-add, badges) sit above it via higher z-index */
  .card__link { text-decoration: none; color: inherit; }
  .card__link::after { content: ''; position: absolute; inset: 0; z-index: 1; }
  .card__link:focus-visible { outline: 2px solid var(--ff-sage); outline-offset: 2px; }
  .card__media { position: relative; overflow: hidden; aspect-ratio: 3/4; background: var(--ff-cream-dk); }
  .card__media img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s cubic-bezier(.25,.46,.45,.94); }
  .card:hover .card__media img { transform: scale(1.06); }
  .card__media-placeholder {
    width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;
    background: var(--ff-cream-dk); color: var(--ff-stone);
  }
  .card-information { padding: 0.9rem 0.95rem 1.1rem; }
  .card__vendor {
    font-size: 0.6rem; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--ff-gold, #B8936A); margin: 0 0 0.35rem;
  }
  .card__heading {
    font-family: var(--ff-font-heading);
    font-size: 0.95rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.03em;
    margin: 0 0 0.45rem; line-height: 1.25;
    transition: color var(--ff-transition);
  }
  .card:hover .card__heading { color: var(--ff-sage-dk); }
  .card__price {
    margin-top: 0.5rem; padding-top: 0.5rem;
    border-top: 1px solid rgba(38, 48, 40, 0.07);
  }
  .price { font-weight: 600; font-size: 0.92rem; letter-spacing: 0.01em; }
  .price--on-sale .price-item--sale { color: var(--ff-sage-dk); }
  .price--on-sale .price-item--regular { text-decoration: line-through; color: var(--ff-stone-lt); margin-left: 0.35rem; font-size: 0.78rem; font-weight: 400; }
  .badge {
    position: absolute; top: 0.75rem; left: 0.75rem; z-index: 3;
    padding: 0.32rem 0.7rem; font-size: 0.58rem; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
    border-radius: var(--ff-radius-pill);
    box-shadow: 0 2px 8px rgba(38, 48, 40, 0.18);
  }
  .badge--sale { background: var(--ff-sage); color: #fff; }
  .badge--sold-out { background: var(--ff-charcoal); color: var(--ff-cream); top: auto; bottom: 0.75rem; box-shadow: none; }
</style>
