<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#26292A">

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <!-- Canonical & OG -->
  <link rel="canonical" href="{{ canonical_url }}">
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:title" content="{{ page_title | escape }}">
  {% if page_description %}
    <meta property="og:description" content="{{ page_description | escape }}">
  {% endif %}
  {% if page_image %}
    <meta property="og:image" content="https:{{ page_image | image_url: width: 1200 }}">
  {% endif %}

  <!-- Favicon -->
  {% if settings.favicon %}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {% endif %}

  <!-- Twitter card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ page_title | escape }}">
  {% if page_description %}<meta name="twitter:description" content="{{ page_description | escape }}">{% endif %}
  {% if page_image %}<meta name="twitter:image" content="https:{{ page_image | image_url: width: 1200 }}">{% endif %}

  <!-- Structured data: Organisation -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "url": {{ shop.url | json }},
    "logo": "{{ shop.url }}/cdn/shop/files/form-and-favour-logo.png",
    "contactPoint": { "@type": "ContactPoint", "email": "hello@formandfavour.co.uk", "contactType": "customer service" }
  }
  </script>

  {%- if template.name == 'product' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": {{ product.title | json }},
    "description": {{ product.description | strip_html | json }},
    "image": [{{ product.images | map: 'src' | json }}],
    "brand": { "@type": "Brand", "name": {{ product.vendor | json }} },
    "offers": {
      "@type": "Offer",
      "priceCurrency": "GBP",
      "price": {{ product.price | divided_by: 100.0 | json }},
      "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
      "url": {{ canonical_url | json }}
    }
  }
  </script>
  {%- endif -%}

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

  <!-- Theme CSS -->
  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ 'form-favour.css' | asset_url | stylesheet_tag }}

  {{ content_for_header }}
</head>

<body class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">

  {%- section 'announcement-bar' -%}
  {%- section 'header' -%}

  <main id="main-content" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {%- section 'footer' -%}

  {%- render 'cart-drawer' -%}
  {%- render 'cookie-banner' -%}
  {%- render 'newsletter-popup' -%}

  <!-- Theme config for JS -->
  <script>
    window.FF = {
      currencySymbol: {{ shop.currency | json }} == 'GBP' ? '£' : '{{ shop.currency }}',
      freeShippingThreshold: 5000,
      allProductsUrl: {{ routes.all_products_collection_url | json }},
      cartUrl: {{ routes.cart_url | json }}
    };
  </script>
  {{ 'theme.js' | asset_url | script_tag }}

</body>
</html>
